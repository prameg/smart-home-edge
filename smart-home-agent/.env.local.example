# Copy to .env.local (git-ignored) for running the agent on your machine against
# a local broker + your Home Assistant VM. Loaded by scripts/run-local.sh.

# --- Home Assistant (the VM at homeassistant.local:8123) -------------------
# Create a Long-Lived Access Token in HA: Profile -> Security -> Long-lived
# access tokens. The agent uses it exactly like the Supervisor-injected token.
SUPERVISOR_TOKEN=paste-the-long-lived-access-token
HA_REST_BASE_URL=http://homeassistant.local:8123/api
HA_WEBSOCKET_URL=ws://homeassistant.local:8123/api/websocket

# --- Broker (local Mosquitto from infra/local) -----------------------------
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TLS=false

# --- Data dir (credentials, applied versions, entity map override) ----------
AGENT_DATA_DIR=./.data

LOG_LEVEL=debug

# --- Cloud (only needed if you want the agent to self-provision) ------------
# Leave blank to run WITHOUT the cloud: pre-seed .data/agent-creds.json instead
# (see docs/local-testing.md, "Track 1"). Fill these to provision against a
# local Laravel cloud (Track 2).
# CLOUD_BASE_URL=http://localhost
# FACTORY_KEY=your-SMART_HOME_PROVISIONING_FACTORY_KEY
# GATEWAY_SERIAL=DEV-0001

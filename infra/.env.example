# Copy to infra/.env and fill in. Never commit the real .env.

# The Laravel cloud host (no scheme) + port. go-auth calls the broker-auth
# callbacks here directly over TLS. If go-auth fails DNS resolution, use the IP.
CLOUD_HOST=app.example.com
CLOUD_PORT=443

# Must equal SMART_HOME_BROKER_AUTH_SECRET in the cloud's environment. Carried in
# the callback URL PATH (/api/v1/broker/<SECRET>/auth), so keep it URL-safe
# (alphanumeric). This is the whole broker->cloud authentication (client-cert
# mTLS is deferred).
SMART_HOME_BROKER_AUTH_SECRET=replace-with-the-cloud-broker-secret
